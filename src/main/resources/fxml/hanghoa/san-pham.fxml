<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom6.qlbh.controller.hanghoa.SanPhamController"
      styleClass="module-root"
      stylesheets="@/css/style.css"
      spacing="0">

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
        <Label text="Tìm kiếm:" styleClass="toolbar-label"/>
        <TextField fx:id="txtSearch" promptText="Mã SP / Tên SP..." prefWidth="220"
                   styleClass="toolbar-field" onAction="#onSearch"/>
        <Label text="Loại:" styleClass="toolbar-label"/>
        <ComboBox fx:id="cboLoai" prefWidth="160" styleClass="toolbar-field"/>
        <Button text="Tìm" styleClass="btn-search" onAction="#onSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnThem" text="+ Thêm SP" styleClass="btn-primary" onAction="#onThem"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="tblSanPham" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colMaSP"    text="Mã SP"     prefWidth="90"/>
            <TableColumn fx:id="colTenSP"   text="Tên sản phẩm" prefWidth="220"/>
            <TableColumn fx:id="colLoai"    text="Loại"      prefWidth="120"/>
            <TableColumn fx:id="colGiaVon"  text="Giá vốn"   prefWidth="110" style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colGiaBan"  text="Giá bán"   prefWidth="110" style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colTonKho"  text="Tồn kho"   prefWidth="80"  style="-fx-alignment:CENTER;"/>
            <TableColumn fx:id="colTrangThai" text="Trạng thái" prefWidth="100" style="-fx-alignment:CENTER;"/>
            <TableColumn fx:id="colAction"  text="Thao tác"  prefWidth="130" style="-fx-alignment:CENTER;"/>
        </columns>
        <placeholder><Label text="Không có dữ liệu"/></placeholder>
    </TableView>

    <!-- Status bar -->
    <HBox styleClass="statusbar" alignment="CENTER_LEFT">
        <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
        <Label fx:id="lblCount" text="0 sản phẩm" styleClass="status-label"/>
    </HBox>
</VBox>
