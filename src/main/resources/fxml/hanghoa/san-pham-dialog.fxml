<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom6.qlbh.controller.hanghoa.SanPhamDialogController"
      styleClass="dialog-root"
      stylesheets="@/css/style.css"
      spacing="0" prefWidth="440">

    <Label fx:id="lblTitle" text="Thêm sản phẩm" styleClass="dialog-title"/>

    <GridPane styleClass="dialog-form" hgap="12" vgap="10">
        <padding><Insets top="16" right="20" bottom="8" left="20"/></padding>

        <Label text="Mã SP *" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="txtMaSP" promptText="VD: SP001" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Tên SP *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="txtTenSP" promptText="Tên sản phẩm" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Loại SP" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="cboLoai" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Giá vốn *" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="txtGiaVon" promptText="0" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Giá bán *" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="txtGiaBan" promptText="0" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Trạng thái" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="cboTrangThai" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <columnConstraints>
            <ColumnConstraints minWidth="90" prefWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS" prefWidth="270"/>
        </columnConstraints>
    </GridPane>

    <Label fx:id="lblError" styleClass="form-error" wrapText="true">
        <VBox.margin><Insets left="20" right="20"/></VBox.margin>
    </Label>

    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <padding><Insets top="12" right="20" bottom="16" left="20"/></padding>
        <Button text="Hủy" styleClass="btn-cancel" onAction="#onCancel"/>
        <Button fx:id="btnLuu" text="Lưu" styleClass="btn-primary" onAction="#onLuu" defaultButton="true"/>
    </HBox>
</VBox>
