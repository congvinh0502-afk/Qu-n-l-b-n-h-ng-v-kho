<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom6.qlbh.controller.banhang.HoaDonInController"
      stylesheets="@/css/style.css"
      style="-fx-background-color:#eeeeee;"
      prefWidth="700" prefHeight="660" minWidth="620" minHeight="500">

    <!-- Title bar -->
    <HBox styleClass="form-title-bar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
        <Label text="Xem trước hóa đơn" styleClass="form-page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblMaHD" styleClass="form-ma-gd"/>
    </HBox>

    <!-- Invoice preview area -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:#eeeeee; -fx-background:transparent;">
        <VBox fx:id="printContainer" alignment="CENTER"
              style="-fx-background-color:#eeeeee; -fx-padding:20;"/>
    </ScrollPane>

    <!-- Footer buttons -->
    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
        <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
        <Button fx:id="btnIn" text="In hóa đơn" styleClass="btn-primary" onAction="#onIn"/>
        <Button text="Đóng" styleClass="btn-cancel" onAction="#onDong"/>
    </HBox>
</VBox>
