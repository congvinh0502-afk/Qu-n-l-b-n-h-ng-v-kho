<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom6.qlbh.controller.banhang.HoaDonFormController"
      fx:id="formRoot" styleClass="module-root" stylesheets="@/css/style.css" spacing="0">

    <HBox styleClass="form-title-bar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
        <Label text="Tạo hóa đơn bán hàng" styleClass="form-page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblMaHD" text="" styleClass="form-ma-gd"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="form-scroll">
        <VBox spacing="12">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <!-- Customer info -->
            <VBox styleClass="form-card" spacing="10">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label text="Thông tin đơn hàng" styleClass="card-title"/>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Khách hàng:" styleClass="form-label" minWidth="100"/>
                    <ComboBox fx:id="cboKhachHang" prefWidth="280"/>
                    <Label text="(Để trống = khách lẻ)" styleClass="toolbar-label"/>
                </HBox>
            </VBox>

            <!-- Add product -->
            <VBox styleClass="form-card" spacing="10">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label text="Thêm sản phẩm" styleClass="card-title"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="txtMaSP" promptText="Mã SP" prefWidth="100" onAction="#onTraCuu"/>
                    <Button text="Tra cứu" styleClass="btn-search" onAction="#onTraCuu"/>
                    <TextField fx:id="txtTenSP" promptText="Tên sản phẩm" prefWidth="200" editable="false" styleClass="readonly-field"/>
                    <Label text="SL:" styleClass="toolbar-label"/>
                    <TextField fx:id="txtSoLuong" promptText="1" prefWidth="60" onAction="#onThemSP"/>
                    <Label text="Đơn giá:" styleClass="toolbar-label"/>
                    <TextField fx:id="txtDonGia" promptText="0" prefWidth="110" onAction="#onThemSP"/>
                    <Button text="+ Thêm" styleClass="btn-primary" onAction="#onThemSP"/>
                </HBox>
                <Label fx:id="lblAddError" styleClass="form-error"/>
                <Label fx:id="lblTonKho" text="" styleClass="status-label"/>
            </VBox>

            <!-- Detail table -->
            <VBox styleClass="form-card" spacing="8">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label text="Danh sách sản phẩm" styleClass="card-title"/>
                <TableView fx:id="tblChiTiet" prefHeight="200" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="ctColMaSP"   text="Mã SP"      prefWidth="90"/>
                        <TableColumn fx:id="ctColTenSP"  text="Tên SP"     prefWidth="220"/>
                        <TableColumn fx:id="ctColSL"     text="SL"         prefWidth="60"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="ctColDonGia" text="Đơn giá"    prefWidth="120" style="-fx-alignment:CENTER_RIGHT;"/>
                        <TableColumn fx:id="ctColThanh"  text="Thành tiền" prefWidth="130" style="-fx-alignment:CENTER_RIGHT;"/>
                        <TableColumn fx:id="ctColXoa"    text="Xóa"        prefWidth="55"  style="-fx-alignment:CENTER;"/>
                    </columns>
                    <placeholder><Label text="Chưa có sản phẩm"/></placeholder>
                </TableView>
            </VBox>

            <!-- Summary + Payment -->
            <VBox styleClass="form-card" spacing="8">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <GridPane hgap="16" vgap="8">
                    <Label text="Tổng tiền hàng:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                    <Label fx:id="lblTongTien" text="0 đ" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight:bold;"/>

                    <Label text="Giảm giá:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                    <TextField fx:id="txtGiamGia" text="0" prefWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="1" onKeyReleased="#onGiamGiaChanged"/>

                    <Label text="Tổng sau giảm:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                    <Label fx:id="lblSauGiam" text="0 đ" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="total-label"/>

                    <Label text="Thanh toán ngay:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                    <HBox spacing="8" GridPane.rowIndex="3" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                        <TextField fx:id="txtTrNgay" text="0" prefWidth="130" onKeyReleased="#onTrNgayChanged"/>
                        <ComboBox fx:id="cboHinhThuc" prefWidth="150"/>
                    </HBox>

                    <Label text="Còn lại (công nợ):" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                    <Label fx:id="lblConLai" text="0 đ" GridPane.rowIndex="4" GridPane.columnIndex="1"
                           style="-fx-text-fill:#e65100;-fx-font-weight:bold;"/>

                    <columnConstraints>
                        <ColumnConstraints minWidth="140" prefWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                </GridPane>
            </VBox>
        </VBox>
    </ScrollPane>

    <HBox styleClass="form-footer" spacing="10" alignment="CENTER_RIGHT">
        <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
        <Button text="← Hủy" styleClass="btn-cancel" onAction="#onHuy"/>
        <Button fx:id="btnLuu" text="Lưu hóa đơn" styleClass="btn-primary" onAction="#onLuu"/>
    </HBox>
</VBox>
