<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom6.qlbh.controller.banhang.HoaDonController"
      styleClass="module-root" stylesheets="@/css/style.css" spacing="0">

    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
        <Label text="Trạng thái:" styleClass="toolbar-label"/>
        <ComboBox fx:id="cboFilter" prefWidth="160" styleClass="toolbar-field"/>
        <Button text="Tìm" styleClass="btn-search" onAction="#onSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Tạo hóa đơn" styleClass="btn-primary" onAction="#onTaoHD"/>
    </HBox>

    <TableView fx:id="tblHD" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colMaHD"       text="Mã HĐ"       prefWidth="80"/>
            <TableColumn fx:id="colKhachHang"  text="Khách hàng"  prefWidth="150"/>
            <TableColumn fx:id="colNhanVien"   text="Nhân viên"   prefWidth="110"/>
            <TableColumn fx:id="colThoiGian"   text="Thời gian"   prefWidth="130"/>
            <TableColumn fx:id="colTongTien"   text="Tổng tiền"   prefWidth="110" style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colGiamGia"    text="Giảm giá"    prefWidth="85"  style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colSauGiam"    text="Sau giảm"    prefWidth="110" style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colDaTT"       text="Đã TT"       prefWidth="100" style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colConNo"      text="Còn nợ"      prefWidth="100" style="-fx-alignment:CENTER_RIGHT;"/>
            <TableColumn fx:id="colTrangThai"  text="Trạng thái"  prefWidth="100" style="-fx-alignment:CENTER;"/>
            <TableColumn fx:id="colAction"     text="Thao tác"    prefWidth="150" style="-fx-alignment:CENTER;"/>
        </columns>
        <placeholder><Label text="Không có hóa đơn"/></placeholder>
    </TableView>

    <HBox styleClass="statusbar" alignment="CENTER_LEFT">
        <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
        <Label fx:id="lblCount" text="0 hóa đơn" styleClass="status-label"/>
    </HBox>
</VBox>
