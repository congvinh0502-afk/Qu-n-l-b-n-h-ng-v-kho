<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom6.qlbh.controller.dashboard.DashboardController"
      styleClass="module-root"
      stylesheets="@../../css/style.css"
      spacing="0">

    <!-- Title bar -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding:14 16 10 16;">
        <Label text="TỔNG QUAN HỆ THỐNG" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblNgayHienTai" style="-fx-font-size:13px;-fx-text-fill:#757575;"/>
        <Button text="↺ Làm mới" styleClass="btn-search" onAction="#onRefresh"/>
    </HBox>

    <!-- 4 KPI Cards -->
    <HBox spacing="12" style="-fx-padding:0 16 12 16;">
        <!-- Doanh thu hôm nay -->
        <VBox styleClass="dash-card dash-card-green" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="DOANH THU HÔM NAY" styleClass="dash-card-label"/>
            <Label fx:id="lblDoanhThuHomNay" text="—" styleClass="dash-card-value"/>
            <Label text="đồng" styleClass="dash-card-unit"/>
        </VBox>
        <!-- Số hóa đơn hôm nay -->
        <VBox styleClass="dash-card dash-card-blue" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="HÓA ĐƠN HÔM NAY" styleClass="dash-card-label"/>
            <Label fx:id="lblSoHDHomNay" text="—" styleClass="dash-card-value"/>
            <Label text="hóa đơn" styleClass="dash-card-unit"/>
        </VBox>
        <!-- Hàng sắp hết -->
        <VBox styleClass="dash-card dash-card-orange" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="HÀNG SẮP HẾT" styleClass="dash-card-label"/>
            <Label fx:id="lblSoHangSapHet" text="—" styleClass="dash-card-value"/>
            <Label text="mặt hàng" styleClass="dash-card-unit"/>
        </VBox>
        <!-- Tổng khách hàng -->
        <VBox styleClass="dash-card dash-card-purple" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="KHÁCH HÀNG" styleClass="dash-card-label"/>
            <Label fx:id="lblSoKhachHang" text="—" styleClass="dash-card-value"/>
            <Label text="khách hàng" styleClass="dash-card-unit"/>
        </VBox>
    </HBox>

    <!-- Charts + Top 5 -->
    <HBox VBox.vgrow="ALWAYS" spacing="12" style="-fx-padding:0 16 16 16;">

        <!-- BarChart doanh thu 7 ngày -->
        <VBox styleClass="chart-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="Doanh thu 7 ngày gần nhất" styleClass="chart-title"/>
            <BarChart fx:id="barChart7Ngay" VBox.vgrow="ALWAYS"
                      animated="false" legendVisible="false" prefHeight="320">
                <xAxis><CategoryAxis label="Ngày"/></xAxis>
                <yAxis><NumberAxis label="VNĐ"/></yAxis>
            </BarChart>
        </VBox>

        <!-- Top 5 sản phẩm bán chạy -->
        <VBox styleClass="chart-card" prefWidth="380" spacing="6">
            <Label text="Top 5 sản phẩm bán chạy" styleClass="chart-title"/>
            <TableView fx:id="tblTop5" VBox.vgrow="ALWAYS" styleClass="data-table" prefHeight="320">
                <columns>
                    <TableColumn fx:id="topColTen"   text="Sản phẩm"   prefWidth="180"/>
                    <TableColumn fx:id="topColSL"    text="SL bán"     prefWidth="70"/>
                    <TableColumn fx:id="topColDT"    text="Doanh thu"  prefWidth="120"/>
                </columns>
                <placeholder><Label text="Chưa có dữ liệu"/></placeholder>
            </TableView>
        </VBox>

    </HBox>

</VBox>
